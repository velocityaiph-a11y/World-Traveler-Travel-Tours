rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /branding/config {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.email == 'velocityaiph@gmail.com';
    }
    
    // Fallback for any collection in this path
    match /branding/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.email == 'velocityaiph@gmail.com';
    }
  }
}
