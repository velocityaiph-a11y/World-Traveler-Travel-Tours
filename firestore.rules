rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Public read for branding
    // This covers both branding/config and any other docs in branding
    match /branding/{docId} {
      allow read: if true;
      allow write: if request.auth != null 
                  && request.auth.token.email == 'velocityaiph@gmail.com';
    }
    
    // Explicitly allow branding sub-collections if any (none currently, but shared for future)
    match /branding/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null 
                  && request.auth.token.email == 'velocityaiph@gmail.com';
    }
  }
}
