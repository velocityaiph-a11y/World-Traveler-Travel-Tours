rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Explicit permission for the admin user
    match /branding/config {
      allow read, write: if true;
    }
    
    // Fallback for branding collection
    match /branding/{doc} {
      allow read, write: if true;
    }

    // Global debug fallback
    match /{document=**} {
      allow read, write: if true;
    }
  }
}
