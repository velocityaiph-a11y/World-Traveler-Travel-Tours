rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isAdmin() {
      return isEmailVerified() && request.auth.token.email == 'velocityaiph@gmail.com';
    }

    function incoming() {
      return request.resource.data;
    }

    function isValidBranding(data) {
      // Basic schema check
      return data.logos is list &&
             data.logos.size() <= 4 &&
             (data.updatedAt is timestamp || data.updatedAt == request.time) &&
             data.updatedBy is string &&
             data.updatedByEmail is string;
    }

    // Branding configuration rules
    match /branding/config {
      // Allow read for everyone
      allow get: if true;
      
      // Allow creation
      allow create: if isAdmin() && 
                      incoming().keys().hasAll(['logos', 'updatedAt', 'updatedBy', 'updatedByEmail']) &&
                      isValidBranding(incoming());

      // Allow updates
      allow update: if isAdmin() && 
                      isValidBranding(incoming()) &&
                      // Ensure it's one of our expected actions
                      incoming().diff(resource.data).affectedKeys().hasOnly(['logos', 'updatedAt', 'updatedBy', 'updatedByEmail']);
    }
  }
}
